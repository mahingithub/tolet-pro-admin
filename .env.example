# ─── TO-LET PRO Admin Console — environment ─────────────────────────────────
# Copy to `.env.local` for local dev, or set these in your host (Vercel etc.).

# Base URL of the backend API, INCLUDING the /api suffix, no trailing slash.
#   Local:      http://localhost:5000/api
#   Production: https://api.tolet-pro.com/api
VITE_API_BASE_URL=http://localhost:5000/api
